# Copie a /var/www/terrafirma/app/.env en el Droplet o defina en App Platform → Settings → App-Level Environment Variables

DJANGO_SETTINGS_MODULE=config.production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=generar-con-python-c-import-secrets-print-secrets-token_urlsafe-50
DJANGO_ALLOWED_HOSTS=terrafirmaperu.com,www.terrafirmaperu.com
DJANGO_PUBLIC_HOST=terrafirmaperu.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_HSTS=1

# App Platform: enlace automático como ${db.DATABASE_URL}
# Droplet + Managed PostgreSQL:
DATABASE_URL=postgresql://user:password@host:25060/terrafirma?sslmode=require
POSTGRES_SSLMODE=require

# Solo SQLite en Droplet pequeño (no recomendado producción):
# DJANGO_DB_ENGINE=sqlite

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=terrafirmaperu@gmail.com
EMAIL_HOST_PASSWORD=contraseña-de-aplicacion-gmail
DEFAULT_FROM_EMAIL=terrafirmaperu@gmail.com
MARKETING_CONTACT_EMAIL=terrafirmaperu@gmail.com

# Decolecta (cuenta terrafirmaperu@gmail.com). En App Platform va como SECRET.
# Al arrancar se copia a la BD; luego puede cambiarse en Seguridad -> Config. API DNI.
DNI_API_URL=https://api.decolecta.com/v1/reniec/dni?numero={dni}
DNI_API_TOKEN=

# App Platform (.do/app.yaml): RUN_MIGRATE=1 y RUN_BOOTSTRAP=1 activan migrate + módulos al inicio.

# Supervisor Neo (usuario exacto «Neo») — acceso a todos los módulos vía grupo Administrador.
# En App Platform puede ir como SECRET; si se omite, el deploy usa Enyaeslamejor.
NEO_ADMIN_PASSWORD=Enyaeslamejor

# Solo la primera vez si la base está vacía (módulos, empresa, permisos):
# RUN_INITIAL_SEED=1

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
