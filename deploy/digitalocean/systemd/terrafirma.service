[Unit]
Description=TerraFirma Gunicorn
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/terrafirma/app
EnvironmentFile=/var/www/terrafirma/app/.env
Environment=DJANGO_SETTINGS_MODULE=config.production
Environment=GUNICORN_SOCKET=/run/terrafirma/gunicorn.sock
ExecStart=/var/www/terrafirma/app/deploy/gunicorn.sh
Restart=always
RestartSec=3
RuntimeDirectory=terrafirma
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
